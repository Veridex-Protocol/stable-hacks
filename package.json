{
  "name": "veridex-treasury-guard",
  "version": "1.0.0",
  "private": true,
  "description": "Veridex Treasury Guard — Compliance-native cross-border stablecoin treasury on Solana",
  "type": "module",
  "scripts": {
    "predev": "node -e \"import('node:fs').then((fs) => fs.rmSync('.next', { recursive: true, force: true }))\"",
    "dev": "npm run prisma:generate && npm run prisma:push && concurrently \"npm run dev:server\" \"next dev --webpack\"",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "next build --webpack",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "check:resources": "tsx src/server/scripts/validateResources.ts",
    "start": "next start"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@solana/spl-token": "^0.4.6",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.95.4",
    "@veridex/agentic-payments": "https://registry.npmjs.org/@veridex/agentic-payments/-/agentic-payments-2.0.4.tgz",
    "@veridex/sdk": "^1.1.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "bigint-buffer": "^1.1.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
