{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "src",
    "noEmit": false
  },
  "include": ["src/server/**/*", "src/server/types/**/*"],
  "exclude": ["src/client/**/*", "dist", "node_modules"]
}
